rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /portfolio/content {
      // The public portfolio needs read-only access to its published content.
      allow read: if true;

      // Only Firebase users granted the `admin: true` custom claim can edit.
      // Set this claim with the Firebase Admin SDK before deploying the rules.
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
